<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>VORTEX GRIMOIRE</title>
    <link href="fonts/fonts.css" rel="stylesheet">
    <link rel="stylesheet" href="lib/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="pixel_scrollbars.css">
    <style>
        :root {
            /* Palette: Archive Data */
            --bg-body: #080810;
            --bg-sidebar: #101018;
            --bg-content: #080810;
            --border: #444455;
            
            --accent: #9b59b6; /* Purple/Magic for Grimoire */
            --accent-glow: rgba(155, 89, 182, 0.3);
            --text-main: #d0d0ff;
            --text-dim: #777799;
            
            --font-pixel: 'VT323', monospace;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0; padding: 0; background: var(--bg-body); color: var(--text-main);
            font-family: var(--font-pixel); font-size: 20px;
            display: flex; height: 100vh; overflow: hidden;
        }

        /* --- SIDEBAR --- */
        #doc-nav {
            width: 280px; background: var(--bg-sidebar); border-right: 2px solid var(--border);
            display: flex; flex-direction: column; overflow-y: auto; flex-shrink: 0;
            user-select: none;
        }

        .nav-header {
            padding: 20px; 
            border-bottom: 2px solid var(--border);
            text-align: center;
        }
        .nav-header h2 { margin: 0; color: var(--accent); text-shadow: 0 0 10px var(--accent-glow); letter-spacing: 2px; }
        .nav-header span { font-size: 14px; color: var(--text-dim); }

        .search-box {
            padding: 10px; border-bottom: 2px solid var(--border);
        }
        .search-input {
            width: 100%; background: #000; border: 1px solid var(--border);
            color: var(--text-main); font-family: inherit; font-size: 18px; padding: 5px 10px;
        }
        .search-input:focus { outline: none; border-color: var(--accent); }

        .nav-group { margin-top: 15px; }
        .nav-title {
            padding: 5px 20px; color: var(--text-dim); font-size: 16px; 
            text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #222; margin-bottom: 5px;
        }

        .nav-item {
            padding: 8px 25px; cursor: pointer; color: #aaa; display: flex; align-items: center; gap: 10px;
            text-decoration: none; border-left: 4px solid transparent;
            transition: all 0.1s;
        }
        .nav-item:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .nav-item.active { 
            background: rgba(155, 89, 182, 0.1); 
            color: var(--accent); 
            border-left-color: var(--accent); 
        }

        /* --- CONTENT --- */
        #doc-content {
            flex-grow: 1; padding: 0; overflow-y: auto; 
            background: var(--bg-content); scroll-behavior: smooth;
            position: relative;
        }

        .content-bg {
            position: fixed; top: 0; left: 280px; width: calc(100% - 280px); height: 100%; z-index: 0;
            background-image: radial-gradient(circle at 50% 50%, rgba(20, 20, 40, 0.5) 0%, transparent 70%);
            pointer-events: none;
        }

        .content-wrapper { 
            max-width: 900px; margin: 0 auto; padding: 40px 60px; position: relative; z-index: 1; 
        }

        section { display: none; margin-bottom: 60px; animation: slideIn 0.3s ease-out; }
        section.active { display: block; }
        @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

        h1 { 
            color: var(--accent); font-size: 42px; margin: 0 0 20px 0; padding-bottom: 10px;
            border-bottom: 2px dashed var(--border); text-shadow: 0 0 10px var(--accent-glow);
            display: flex; align-items: center; gap: 15px;
        }
        h2 { 
            margin-top: 40px; color: #fff; font-size: 32px; margin-bottom: 15px;
            border-left: 4px solid var(--accent); padding-left: 10px;
        }
        h3 { margin-top: 25px; color: #aab; font-size: 24px; text-decoration: underline; text-decoration-color: var(--border); }

        p { line-height: 1.6; color: var(--text-main); margin-bottom: 15px; font-size: 20px; }
        ul, ol { margin-bottom: 20px; padding-left: 30px; }
        li { margin-bottom: 8px; color: #bbb; }

        /* --- WIDGETS --- */
        code {
            background: #222; padding: 2px 6px; border: 1px solid #444; color: #f1c40f;
            font-family: 'Consolas', monospace; font-size: 18px;
        }
        pre {
            background: #111; padding: 20px; border: 2px solid var(--border);
            overflow-x: auto; margin: 20px 0; box-shadow: inset 0 0 20px #000;
        }
        pre code {
            background: transparent; padding: 0; border: none; color: #2ecc71; display: block;
        }

        .note {
            background: rgba(52, 152, 219, 0.1); border: 2px solid #3498db;
            padding: 15px; margin: 25px 0; display: flex; align-items: start; gap: 15px;
        }
        .note i { font-size: 24px; color: #3498db; margin-top: 3px; }
        .note.warn {
            background: rgba(231, 76, 60, 0.1); border-color: #e74c3c;
        }
        .note.warn i { color: #e74c3c; }

        table { width: 100%; border-collapse: collapse; margin: 25px 0; border: 2px solid var(--border); }
        th, td { border: 1px solid var(--border); padding: 10px 15px; text-align: left; }
        th { background: #1a1a24; color: var(--accent); }
        tr:nth-child(even) { background: rgba(255,255,255,0.03); }

        .key-badge {
            display: inline-block; border: 2px solid #666; border-bottom-width: 4px;
            border-radius: 4px; padding: 0 6px; background: #333; color: #fff;
            font-size: 16px; font-weight: bold; margin: 0 2px;
        }

    </style>
</head>
<body>

    <nav id="doc-nav">
        <div class="nav-header">
            <h2>GRIMOIRE</h2>
            <span>ARCHIVE V7.0</span>
        </div>
        <div class="search-box">
            <input type="text" class="search-input" placeholder="SEARCH DATABASE..." onkeyup="filterNav(this.value)">
        </div>
        
        <div class="nav-list">
            <div class="nav-group">
                <div class="nav-title">INITIATION</div>
                <a href="#welcome" class="nav-item active"><i class="fas fa-star"></i> Welcome</a>
                <a href="#getting-started" class="nav-item"><i class="fas fa-play"></i> Quick Start</a>
                <a href="#project-structure" class="nav-item"><i class="fas fa-folder-tree"></i> Structure</a>
            </div>

            <div class="nav-group">
                <div class="nav-title">WORKBENCH</div>
                <a href="#tool-dashboard" class="nav-item"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                <a href="#tool-map" class="nav-item"><i class="fas fa-map"></i> Map Editor</a>
                <a href="#tool-prefab" class="nav-item"><i class="fas fa-cubes"></i> Prefabs</a>
                <a href="#tool-script" class="nav-item"><i class="fas fa-code"></i> Scripting</a>
                <a href="#tool-logic" class="nav-item"><i class="fas fa-project-diagram"></i> Logic Graphs</a>
                <a href="#tool-behavior" class="nav-item"><i class="fas fa-brain"></i> AI Behavior</a>
                <a href="#tool-ui" class="nav-item"><i class="fas fa-layer-group"></i> UI Designer</a>
            </div>

            <div class="nav-group">
                <div class="nav-title">SYSTEMS</div>
                <a href="#sys-input" class="nav-item"><i class="fas fa-gamepad"></i> Input</a>
                <a href="#sys-audio" class="nav-item"><i class="fas fa-music"></i> Audio</a>
                <a href="#sys-save" class="nav-item"><i class="fas fa-save"></i> Save/Load</a>
                <a href="#sys-campaign" class="nav-item"><i class="fas fa-flag"></i> Campaign</a>
            </div>

            <div class="nav-group">
                <div class="nav-title">CORE API</div>
                <a href="#api-game" class="nav-item"><i class="fas fa-cogs"></i> Game Object</a>
                <a href="#api-console" class="nav-item"><i class="fas fa-terminal"></i> Console</a>
            </div>
        </div>
    </nav>

    <main id="doc-content">
        <div class="content-bg"></div>
        <div class="content-wrapper">

            <!-- WELCOME -->
            <section id="welcome" class="active">
                <h1><i class="fas fa-book-open"></i> Welcome to Vortex</h1>
                <p><b>Vortex Engine (v7.0)</b> is a hyper-advanced retro development kit. It fuses the soul of 16-bit classics with modern web architecture.</p>
                
                <div class="note">
                    <i class="fas fa-info-circle"></i>
                    <div>
                        <strong>Philosophy:</strong> "Visual where possible, Code where necessary." Every tool writes plain JSON/JS.
                    </div>
                </div>

                <h3>Key Features</h3>
                <ul>
                    <li><b>Hybrid Core:</b> HTML5 Canvas rendering with classic game loop.</li>
                    <li><b>Hot Reload:</b> Modify assets and code while the game runs.</li>
                    <li><b>Universal Build:</b> Export to Windows, Android, and Web instantly.</li>
                </ul>
            </section>

            <!-- GETTING STARTED -->
            <section id="getting-started">
                <h1><i class="fas fa-bolt"></i> Quick Start</h1>
                <p>Initiate your first protocol sequence.</p>

                <h2>1. Genesis</h2>
                <ol>
                    <li>Open <b>Dashboard</b>.</li>
                    <li>Select <b>NEW PROJECT</b>.</li>
                    <li>Input designation (Name) and Architecture (Template).</li>
                    <li>Execute.</li>
                </ol>

                <h2>2. World Building</h2>
                <ol>
                    <li>Launch <b>Map Editor</b>.</li>
                    <li>Paint terrain on "Ground" layer.</li>
                    <li>Paint red tiles on "Collision" layer to define barriers.</li>
                    <li>Save as <code>level1.json</code>.</li>
                </ol>

                <h2>3. Execution</h2>
                <p>Return to Dashboard and initiate <b>RUN GAME</b>. Use <span class="key-badge">WASD</span> to traverse.</p>
            </section>

            <!-- PROJECT STRUCTURE -->
            <section id="project-structure">
                <h1><i class="fas fa-folder-open"></i> Project Structure</h1>
                <p>Standardized directory layout for optimal engine parsing.</p>

                <pre>
MyProject/
├── dunyalar/               # Maps (.json)
│   └── definitions/        # Database files
│       ├── items.json      # Item stats
│       └── enemies.json    # Enemy stats
├── data/
│   ├── logic/              # Visual Scripts
│   ├── brains/             # AI Behaviors
│   └── saves/              # Player Save files
├── public/
│   ├── sprite-art/         # Raw images
│   └── muzikler/           # Audio files
└── package.json            # Manifest</pre>

                <div class="note warn">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                        <strong>Warning:</strong> Core directory names are hardcoded into the kernel. Do not rename.
                    </div>
                </div>
            </section>

            <!-- MAP EDITOR -->
            <section id="tool-map">
                <h1><i class="fas fa-map"></i> Map Editor</h1>
                <p>The primary spatial construction tool.</p>

                <h3>Layer Stack</h3>
                <ul>
                    <li><b>Ground:</b> Base terrain.</li>
                    <li><b>Decoration:</b> Objects (rocks, flowers).</li>
                    <li><b>Collision:</b> Physics barriers.</li>
                    <li><b>Entities:</b> Actor spawn points.</li>
                    <li><b>Above:</b> Foreground elements (tree tops).</li>
                </ul>
            </section>

            <!-- PREFAB EDITOR -->
            <section id="tool-prefab">
                <h1><i class="fas fa-cubes"></i> Prefab Editor</h1>
                <p>Blueprints for Game Objects. Define once, spawn anywhere.</p>

                <h3>Components</h3>
                <table>
                    <tr><th>ID</th><th>Function</th></tr>
                    <tr><td><b>Sprite</b></td><td>Visual rendering.</td></tr>
                    <tr><td><b>Transform</b></td><td>Spatial coordinates & bbox.</td></tr>
                    <tr><td><b>Stats</b></td><td>HP, Speed, Atk.</td></tr>
                    <tr><td><b>Brain</b></td><td>AI controller.</td></tr>
                </table>
            </section>

            <!-- SCRIPTING -->
            <section id="tool-script">
                <h1><i class="fas fa-code"></i> Scripting</h1>
                <p>Logic implementation via ES6 Modules.</p>

                <h3>Syntax Example</h3>
                <pre>
export async function runLogic(entity, game, ui) {
    game.log("Script init...");
    
    // Move entity
    await entity.walkTo(100, 200);
    
    // Audio trigger
    game.audio.play('beep');
    
    // UI Interaction
    game.dialogueSystem.start('welcome');
}</pre>
            </section>

            <!-- UI DESIGNER -->
            <section id="tool-ui">
                <h1><i class="fas fa-layer-group"></i> UI Designer</h1>
                <p>Interface layout tool for HUDs and Menus.</p>
                <p>Supports anchoring, scaling, and data-binding to player variables.</p>
            </section>

            <!-- DASHBOARD -->
            <section id="tool-dashboard">
                <h1><i class="fas fa-tachometer-alt"></i> Dashboard</h1>
                <p>The OS shell. Provides project management, system config, and tool access.</p>
            </section>

            <!-- LOGIC GRAPHS -->
            <section id="tool-logic">
                <h1><i class="fas fa-project-diagram"></i> Logic Graphs</h1>
                <p>Node-based visual scripting for event chains.</p>
                <p><b>Nodes:</b> Events, Actions, Conditions, Variables.</p>
            </section>

            <!-- AI BEHAVIOR -->
            <section id="tool-behavior">
                <h1><i class="fas fa-brain"></i> AI Behavior</h1>
                <p>Behavior Tree editor for autonomous agents.</p>
                <p><b>Structure:</b> Root -> Selector -> Sequence -> Task.</p>
            </section>

            <!-- INPUT SYSTEM -->
            <section id="sys-input">
                <h1><i class="fas fa-gamepad"></i> Input System</h1>
                <p>Action-based input abstraction.</p>
                <table>
                    <tr><th>Action</th><th>Key</th><th>Pad</th></tr>
                    <tr><td>Move</td><td><span class="key-badge">WASD</span></td><td>L-Stick</td></tr>
                    <tr><td>Interact</td><td><span class="key-badge">E</span></td><td>A / X</td></tr>
                    <tr><td>Sprint</td><td><span class="key-badge">SHIFT</span></td><td>R-Trig</td></tr>
                </table>
            </section>

            <!-- AUDIO SYSTEM -->
            <section id="sys-audio">
                <h1><i class="fas fa-music"></i> Audio System</h1>
                <p>Web Audio API wrapper with spatial support.</p>
                <ul>
                    <li><b>Spatial 3D:</b> Position-based panning/volume.</li>
                    <li><b>Mixer:</b> Grouped volume control (SFX, BGM).</li>
                </ul>
            </section>

            <!-- SAVE SYSTEM -->
            <section id="sys-save">
                <h1><i class="fas fa-save"></i> Save/Load</h1>
                <p>Automatic serialization of Player State and Inventory.</p>
                <p>Storage Path: <code>data/saves/</code></p>
            </section>

            <!-- CAMPAIGN SYSTEM -->
            <section id="sys-campaign">
                <h1><i class="fas fa-flag"></i> Campaign</h1>
                <p>Linear progression manager. Links Levels and Cutscenes.</p>
            </section>

            <!-- CORE API -->
            <section id="api-game">
                <h1><i class="fas fa-cogs"></i> Game Object</h1>
                <p>Global instance: <code>window.game</code></p>
                <ul>
                    <li><code>game.loadLevel(id)</code></li>
                    <li><code>game.playSound(id)</code></li>
                    <li><code>game.spawnParticle(x, y, ...)</code></li>
                    <li><code>game.player</code> (The Avatar)</li>
                </ul>
            </section>

            <!-- DEBUG CONSOLE -->
            <section id="api-console">
                <h1><i class="fas fa-terminal"></i> Console</h1>
                <p>Access via <span class="key-badge">~</span> key.</p>
                <pre>
> god        // Invincibility
> noclip     // Ghost mode
> speed 500  // Set velocity
> give potion_hp</pre>
            </section>

        </div>
    </main>

    <script>
        // Navigation Logic
        const links = document.querySelectorAll('.nav-item');
        const sections = document.querySelectorAll('section');

        function activateSection(id) {
            links.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + id));
            sections.forEach(s => s.classList.toggle('active', s.id === id));
            document.getElementById('doc-content').scrollTop = 0;
        }

        links.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const id = link.getAttribute('href').substring(1);
                activateSection(id);
            });
        });

        // Filter
        window.filterNav = (term) => {
            term = term.toLowerCase();
            links.forEach(l => {
                const txt = l.innerText.toLowerCase();
                const visible = txt.includes(term);
                l.style.display = visible ? 'flex' : 'none';
            });
            // Hide empty groups
            document.querySelectorAll('.nav-group').forEach(g => {
                const visChildren = Array.from(g.querySelectorAll('.nav-item')).filter(i => i.style.display !== 'none');
                g.style.display = visChildren.length > 0 ? 'block' : 'none';
            });
        };

        // Deep linking
        const hash = window.location.hash.substring(1);
        if(hash && document.getElementById(hash)) {
            activateSection(hash);
        } else {
            activateSection('welcome');
        }
    </script>
</body>
</html>
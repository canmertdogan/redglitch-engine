<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KETEBE | The AI-Native Retro Engine</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=VT323&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body class="pro-retro">
    <div id="bootloader">
        <div class="boot-text">
            <div>KETEBE_BOOTLOADER_v1.0.0</div>
            <div id="boot-progress">INITIALIZING_SYSTEM_CORES...</div>
        </div>
    </div>
    <div class="crt-overlay"></div>

    <!-- HIGH-TECH NAVIGATION -->
    <nav class="nav-pro">
        <div class="nav-container">
            <div class="nav-brand">
                <img src="assets/logo.png" alt="Logo">
                <span>KETEBE_v1.0.0</span>
            </div>
            <div class="nav-links">
                <a href="#cores">SYSTEM_CORES</a>
                <a href="#kai">KAI_COIL</a>
                <a href="#studio">WORKSHOP</a>
                <a href="#tech">ARCHITECTURE</a>
                <a href="https://github.com/n0rthstar/ketebe" class="btn-git">GIT_PULL</a>
            </div>
            <button id="menuToggle" class="btn-switcher mobile-only">MENU.EXE</button>
        </div>
    </nav>

    <!-- MOBILE MENU OVERLAY -->
    <div id="mobileMenu" class="mobile-menu-overlay">
        <div class="mobile-menu-content">
            <div class="menu-header">KETEBE_SYSTEM_MENU</div>
            <div class="menu-list">
                <a href="#cores" class="menu-item">> SYSTEM_CORES</a>
                <a href="#kai" class="menu-item">> KAI_COIL</a>
                <a href="#studio" class="menu-item">> WORKSHOP</a>
                <a href="#tech" class="menu-item">> ARCHITECTURE</a>
                <a href="https://github.com/n0rthstar/ketebe" class="menu-item">> GIT_SOURCE</a>
            </div>
            <button id="menuClose" class="btn-sub">CLOSE_SESSION</button>
        </div>
    </div>

    <main class="main-content">
        
        <!-- HERO: THE TERMINAL -->
        <header class="hero-pro">
            <div class="hero-grid">
                <div class="hero-info">
                    <div class="sys-label">[ STATUS: OPTIMAL ]</div>
                    <h1 class="glitch" data-text="BEYOND PIXELS">BEYOND PIXELS</h1>
                    <div class="hero-desc">
                        <p class="typewriter">Ketebe is a multi-paradigm game development ecosystem. We've combined the crunchiest pixel art aesthetics with brain-melting browser AI. Build isometric, platformer, and top-down RPGs with a browser-native assistant that lives in your workspace.</p>
                    </div>
                    <div class="hero-cta">
                        <a href="../public/project_dashboard.html" class="btn-main">INITIALIZE_STUDIO</a>
                        <a href="#tech" class="btn-sub">READ_SPECS.LOG</a>
                    </div>
                </div>
                <div class="hero-frame">
                    <div class="frame-header">
                        <span>ISO_VIEWPORT_v0.4</span>
                        <div class="frame-dots"><span></span><span></span><span></span></div>
                    </div>
                    <div class="frame-body">
                        <canvas id="heroCanvas"></canvas>
                        <div id="hero-log"></div>
                    </div>
                </div>
            </div>
        </header>

        <!-- STATS: THE DATASHEET -->
        <section class="stats-bar">
            <div class="stat-block">
                <span class="stat-val">82K+</span>
                <span class="stat-key">CORE_LINES_OF_CODE</span>
            </div>
            <div class="stat-block">
                <span class="stat-val">60fps</span>
                <span class="stat-key">LOCKED_REFRESH</span>
            </div>
            <div class="stat-block">
                <span class="stat-val">1.3B</span>
                <span class="stat-key">AI_PARAMETERS</span>
            </div>
            <div class="stat-block">
                <span class="stat-val">100%</span>
                <span class="stat-key">LOCAL_STORAGE</span>
            </div>
        </section>

        <!-- CORES: THE QUARTET -->
        <section id="cores" class="section-pro">
            <h2 class="section-title">THE <span class="highlight">SYSTEM_QUARTET</span></h2>
            <div class="pro-grid">
                <div class="pro-card">
                    <div class="card-tag">SYSTEM_01 [ONLINE]</div>
                    <h3>IsoPixel (2.5D)</h3>
                    <p>Advanced isometric rendering with "illegal" lighting tricks and a Day/Night cycle that breathes. Built for tactical depth and complex world-states. Ketebe's IsoPixel core handles millions of tiles with sub-millisecond sorting.</p>
                </div>
                <div class="pro-card">
                    <div class="card-tag">SYSTEM_02 [STABLE]</div>
                    <h3>RPG Top-Down</h3>
                    <p>Heavy systems core with branching dialogue trees, quest management, and NPC schedule logic. The spirit of '94, reborn in the browser with modern reactivity and state-management protocols.</p>
                </div>
                <div class="pro-card">
                    <div class="card-tag">SYSTEM_03 [BETA]</div>
                    <h3>Platformer 2D</h3>
                    <p>Precision-focused physics with AABB collision and butter-smooth camera movement. Every pixel of movement is calculated for tight, responsive gameplay. Built-in animator for frame-perfect character states.</p>
                </div>
                <div class="pro-card">
                    <div class="card-tag">SYSTEM_04 [NEW_0x3D]</div>
                    <h3>TopDown 3D</h3>
                    <p>Our latest breakthrough: Full 3D depth in a retro-constrained world. High-performance rasterization with retro shaders, dynamic perspective, and real depth-of-field. Bridge the gap between 2D nostalgia and 3D immersion.</p>
                </div>
            </div>

            <!-- NEW: ATMOSPHERE ENGINE SHOWCASE -->
            <div class="atmosphere-showcase">
                <div class="showcase-visuals">
                    <div class="atmosphere-frame day">
                        <div class="frame-tag">TIME_PROTOCOL: 1200HR</div>
                        <div class="atmosphere-art day-art"></div>
                    </div>
                    <div class="atmosphere-frame night">
                        <div class="frame-tag">TIME_PROTOCOL: 0000HR</div>
                        <div class="atmosphere-art night-art"></div>
                    </div>
                </div>
                <div class="showcase-content">
                    <div class="sys-label">ATMOSPHERE_v0.5</div>
                    <h3>BEYOND PIXEL COLOR</h3>
                    <p>Ketebe goes beyond just rendering tiles. Our atmosphere engine handles global illumination shifts, procedural vegetation growth, and weather particle systems.</p>
                    <div class="feature-pills">
                        <span>PROCEDURAL_TREES</span>
                        <span>DYNAMIC_SHADOWS</span>
                        <span>AMBIENT_OCCLUSION</span>
                        <span>WEATHER_BUS</span>
                    </div>
                </div>
            </div>

            <!-- NEW: VISUAL PROTOCOL SWITCHER -->
            <div class="visual-switcher-pro">
                <div class="switcher-label">VISUAL_PROTOCOLS.CFG</div>
                <div class="switcher-buttons">
                    <button class="btn-switcher active" data-fx="crt">CRT_ON</button>
                    <button class="btn-switcher active" data-fx="scanlines">SCANLINES_ON</button>
                    <button class="btn-switcher" data-theme="amber">AMBER_MONITOR</button>
                    <button class="btn-switcher" data-theme="green">GREEN_PHOSPHOR</button>
                </div>
            </div>
        </section>

        <!-- KAI: THE NEURAL COIL -->
        <section id="kai" class="section-pro alt-bg">
            <div class="ai-pro-layout">
                <div class="ai-pro-text">
                    <div class="sys-label blue">IRQ_LEVEL_05</div>
                    <h2>KETEBE AI (KAI)</h2>
                    <p>The first game engine with a built-in local brain. KAI uses WebGPU to process your project logic locally. No cloud, no lag, no privacy leaks. It understands your code as you write it, offering real-time architectural insights.</p>
                    <ul class="pro-list">
                        <li><span>></span> LOCAL_INFERENCE: DeepSeek-powered logic suggestions running on your hardware.</li>
                        <li><span>></span> CONTEXT_RAG: Smart awareness of your entire project structure, assets, and logic.</li>
                        <li><span>></span> GHOST_TEXT: Real-time code completion that predicts your next design pattern.</li>
                    </ul>
                </div>
                <div class="ai-pro-visual">
                    <div class="retro-chat-mockup" id="msnChat">
                        <div class="chat-header">
                            <span>KAI_MESSENGER.exe</span>
                            <button id="nudgeBtn">NUDGE</button>
                        </div>
                        <div class="chat-body">
                            <div class="msg bot">Welcome to KAI_v7.0. Neural coil established. How can I help you today?</div>
                            <div class="msg user">Analyze 'Iso_World_1.json' for occlusion bottlenecks.</div>
                            <div class="msg bot">Scanning_Geometry... Found 142 redundant draw calls. Auto-culling applied. Frame stability increased by 14%.</div>
                            <div class="msg bot typing">Ready_for_next_directive...</div>
                        </div>
                    </div>
                    <div id="neuralMapContainer" style="margin-top: 20px;"></div>
                </div>
            </div>
        </section>

        <!-- AUDIO: THE SONIC BOOM (EXPANDED) -->
        <section id="audio" class="section-pro">
            <h2 class="section-title">THE <span class="highlight-blue">SONIC BOOM</span></h2>
            <div class="audio-pro-layout">
                <div class="pro-grid">
                    <div class="pro-card">
                        <h3>Integrated DAW</h3>
                        <p>Full Piano Roll and step sequencer inside the workspace.</p>
                        <div class="sound-test-grid">
                            <button class="btn-sound" data-sound="kick">KICK.WAV</button>
                            <button class="btn-sound" data-sound="snare">SNARE.WAV</button>
                            <button class="btn-sound" data-sound="lead">LEAD_01.SYN</button>
                        </div>
                    </div>
                    <div class="pro-card">
                        <h3>16-Channel Mixer</h3>
                        <p>Real-time FX chains and filter automation.</p>
                        <div class="mixer-mockup">
                            <div class="mixer-track"><div class="fader"></div></div>
                            <div class="mixer-track"><div class="fader"></div></div>
                            <div class="mixer-track"><div class="fader" style="bottom: 40%"></div></div>
                            <div class="mixer-track"><div class="fader" style="bottom: 70%"></div></div>
                        </div>
                    </div>
                    <div class="pro-card">
                        <h3>Spatial Audio</h3>
                        <p>Distance-aware 2.5D sound positioning engine.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- STUDIO: THE WORKSHOP -->
        <section id="studio" class="section-pro">
            <h2 class="section-title">THE <span class="highlight">WORKSHOP</span></h2>
            <div class="studio-pro-grid">
                <div class="studio-pro-item">
                    <div class="studio-img code-forge"></div>
                    <h4>Code_Forge</h4>
                    <p>AI-augmented IDE with real-time vector-RAG context. Features ghost-text autocomplete, hot-module reloading, and a built-in asset pipeline.</p>
                </div>
                <div class="studio-pro-item">
                    <div class="studio-img iso-studio"></div>
                    <h4>IsoPixel_Studio</h4>
                    <p>Visual world architect for massive isometric tilemaps. Integrated vegetation generation, dynamic lighting bakes, and NPC behavior scripting.</p>
                </div>
                <div class="studio-pro-item">
                    <div class="studio-img algorithm-studio"></div>
                    <h4>Algorithm_Studio</h4>
                    <p>Node-based logic flow for complex game states. Bridge the gap between visual intuition and high-performance JS bytecode.</p>
                </div>
            </div>
        </section>

        <!-- ARCHITECTURE: THE SPECS (EXPANDED WITH INTERACTIVE DIAGRAM) -->
        <section id="tech" class="section-pro black-bg">
            <h2 class="section-title">THE <span class="highlight">CORE_ARCHITECTURE</span></h2>
            
            <div class="architecture-visualizer">
                <div class="circuit-board">
                    <div class="node" data-id="gpu" data-info="WEB_GPU_ACCELERATION" style="top: 20%; left: 10%;">GPU_CORE</div>
                    <div class="node" data-id="neural" data-info="TRANSFORMERS_JS_V3" style="top: 20%; right: 10%;">NEURAL_GATE</div>
                    <div class="node" data-id="rag" data-info="ORAMA_VECTOR_DB" style="top: 50%; left: 45%;">RAG_HUB</div>
                    <div class="node" data-id="render" data-info="V8_CANVAS_PIPELINE" style="top: 80%; left: 10%;">RENDER_BUS</div>
                    <div class="node" data-id="native" data-info="ELECTRON_CAPACITOR_BRIDGE" style="top: 80%; right: 10%;">NATIVE_LINK</div>
                    <div class="circuit-lines">
                        <canvas id="circuitCanvas"></canvas>
                    </div>
                </div>
                <div id="architecture-desc" class="terminal-box">
                    > HOVER OVER A SYSTEM MODULE TO INTERROGATE...
                </div>
            </div>

            <div class="tech-grid">
                <div class="tech-card">
                    <h5>NEURAL_CORE</h5>
                    <p>Transformers.js v3 + WebGPU acceleration. 1.3B parameter local inference.</p>
                </div>
                <div class="tech-card">
                    <h5>VECTOR_ENGINE</h5>
                    <p>Orama Hybrid Search with IndexedDB persistence for sub-1ms RAG retrieval.</p>
                </div>
                <div class="tech-card">
                    <h5>RENDER_PIPELINE</h5>
                    <p>V8-optimized canvas rendering with depth-sorting and chunk-based occlusion.</p>
                </div>
                <div class="tech-card">
                    <h5>CROSS_COMPILER</h5>
                    <p>Electron (Desktop) & Capacitor (Mobile) native bridge protocols.</p>
                </div>
            </div>
        </section>

        <!-- SYNC: THE EVENT BUS -->
        <section id="sync" class="section-pro">
            <h2 class="section-title">REAL-TIME <span class="highlight-blue">SYNC_PROTOCOL</span></h2>
            <div class="sync-grid">
                <div class="sync-visual">
                    <div class="sync-window main">
                        <div class="window-label">ISO_EDITOR.exe</div>
                        <div class="window-content">
                            <div class="sync-tile"></div>
                            <div class="sync-tile"></div>
                            <div class="sync-tile active"></div>
                            <div class="sync-tile"></div>
                        </div>
                    </div>
                    <div class="sync-line">
                        <div class="pulse"></div>
                    </div>
                    <div class="sync-window side">
                        <div class="window-label">CODE_FORGE.js</div>
                        <div class="window-content">
                            <pre><code>tile.tint = "#f1c40f";</code></pre>
                        </div>
                    </div>
                </div>
                <div class="sync-info">
                    <div class="sys-label blue">EVENT_BUS_v2.0</div>
                    <h3>THE MULTI-WINDOW HEARTBEAT</h3>
                    <p>Ketebe's editors don't just "save" files. They talk to each other. Through our proprietary EventBus protocol, every change in Code_Forge is instantly reflected in the running game and all open editors. No more refreshing, no more state-desync.</p>
                    <ul class="pro-list">
                        <li><span>></span> ZERO_LATENCY: WebSocket-based state broadcasting.</li>
                        <li><span>></span> DISTRIBUTED_TOOLS: Run editors on different monitors or even different devices.</li>
                        <li><span>></span> HOT_RELOAD: Automatic injection of logic and assets into the active runtime.</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- NEW: EASE OF USE (LIVE SCRIPTING MOCKUP) -->
        <section id="ease-of-use" class="section-pro alt-bg">
            <h2 class="section-title">EASE OF <span class="highlight-blue">DEPLOYMENT</span></h2>
            <div class="hot-reload-playground">
                <div class="playground-code">
                    <div class="frame-header">SCRIPTOR_v1.0</div>
                    <div class="code-editor-mockup">
                        <div class="line"><span>1</span> <span class="keyword">export class</span> <span class="class">Player</span> {</div>
                        <div class="line"><span>2</span>   <span class="func">onUpdate</span>() {</div>
                        <div class="line"><span>3</span>     <span class="this">this</span>.scale = <span class="variable" id="code-scale">1.0</span>;</div>
                        <div class="line"><span>4</span>     <span class="this">this</span>.tint = <span class="string" id="code-tint">"#f1c40f"</span>;</div>
                        <div class="line"><span>5</span>   }</div>
                        <div class="line"><span>6</span> }</div>
                    </div>
                    <div class="code-controls">
                        <button class="btn-switcher" onclick="updateMockup('scale', 1.5)">ENLARGE</button>
                        <button class="btn-switcher" onclick="updateMockup('tint', '#3498db')">BLUE_TINT</button>
                        <button class="btn-switcher" onclick="updateMockup('reset', 1.0)">RESET</button>
                    </div>
                </div>
                <div class="playground-result">
                    <div class="frame-header">LIVE_PREVIEW</div>
                    <div class="result-view">
                        <div id="mockup-sprite">📐</div>
                        <div class="hot-reload-tag">HOT_RELOAD_ACTIVE</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ROADMAP: THE LOG -->
        <section id="roadmap" class="section-pro">
            <h2 class="section-title">THE <span class="highlight">SYSTEM_ROADMAP</span></h2>
            <div class="roadmap-container">
                <div class="roadmap-item completed">
                    <div class="roadmap-ver">v1.0 (CURRENT)</div>
                    <div class="roadmap-desc">Multi-Paradigm Engine, Neural Link v1, Integrated DAW, WebGPU Rasterizer.</div>
                </div>
                <div class="roadmap-item">
                    <div class="roadmap-ver">v1.1 (Q2 2026)</div>
                    <div class="roadmap-desc">Procedural World Generation, Multiplayer WebSocket Relay, Advanced Shaders Lab.</div>
                </div>
                <div class="roadmap-item">
                    <div class="roadmap-ver">v1.2 (Q4 2026)</div>
                    <div class="roadmap-desc">Neural Asset Generation (PixelDiffusion), Native Mobile Bridge (DirectX/Metal), Cloud Sync.</div>
                </div>
            </div>
        </section>

    </main>

    <footer class="footer-pro">
        <div class="footer-container">
            <div class="footer-brand">KETEBE_ENGINE_STUDIO_2026</div>
            <div class="footer-status">BUILD_REV: 0x82A1 // STATUS: NOMINAL // MARCH_2026</div>
            <div class="footer-cta">
                <a href="../public/project_dashboard.html" class="btn-main">RETURN_TO_STUDIO</a>
            </div>
        </div>
    </footer>

    <script src="main.js"></script>
    <script src="visualizer.js"></script>
</body>
</html>

{
  "name": "redglitch-engine",
  "productName": "Redglitch Game Studio",
  "version": "0.1.5-experimental-alpha",
  "description": "Redglitch Game Studio experimental alpha - local-first game creation tools",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "release:build": "npm run beta:check && npm run dist:mac && npm run dist:win && npm run dist:linux",
    "build:game": "node build-game.js",
    "build:game:mac": "node build-game.js \"Default Project\" macos",
    "build:game:ios": "node build-game.js \"Default Project\" ios",
    "build:game:android": "node build-game.js \"Default Project\" android",
    "build:game:win": "node build-game.js \"Default Project\" windows",
    "build:corpus": "node public/ai/docs/build-corpus.js",
    "engine:lockstep": "node scripts/engine-lockstep.js",
    "tools:audit": "node scripts/audit-tool-contracts.js",
    "test:tools": "npm run tools:audit",
    "test": "npm run test:ai && npm run test:server && npm run test:engines",
    "test:ai": "node --test public/ai/agent-loop.test.mjs public/ai/ai-mode.test.mjs public/ai/automation-contract.test.mjs public/ai/tool-call-parser.test.mjs public/ai/project-context-retriever.test.mjs public/ai/tool-aliases.test.mjs public/ai/tool-definitions.test.mjs public/ai/tool-registry.test.mjs public/ai/workflow-manager.test.mjs public/ai/tools/editor-tools.test.mjs",
    "test:server": "node --test --test-concurrency=1 server/utils/pathGuard.test.js server/utils/automationPolicy.test.js server/routes/__tests__/projects.test.js server/routes/__tests__/levels.test.js server/routes/__tests__/campaigns.test.js server/routes/__tests__/levels3d.test.js server/routes/__tests__/gamedata.test.js",
    "test:engines": "node scripts/validate-3d-campaign.js && node --test public/engines/__tests__/shared/ConditionEvaluator.test.js public/engines/__tests__/shared/CrossEngineSerializer.test.js public/engines/__tests__/shared/Save3D.test.mjs public/engines/__tests__/shared/InventorySystem.test.js public/engines/__tests__/shared/AbilityDefinitions.test.js public/engines/__tests__/shared/ItemDefinitions.test.js public/engines/__tests__/shared/CampaignValidator.test.js public/engines/__tests__/platformer-2d/PlatformerConfig.test.js public/engines/__tests__/platformer-2d/AdvancedGenerator.test.js public/engines/__tests__/platformer-2d/SmartGenerator.test.js public/engines/__tests__/platformer-2d/CombatSystem.test.js public/engines/__tests__/platformer-2d/PhysicsSystem.test.js public/engines/__tests__/rpg-topdown/spatialHash.test.js public/engines/__tests__/rpg-topdown/stateMachine.test.js public/engines/__tests__/rpg-topdown/BrainRuntime.test.js public/engines/__tests__/rpg-topdown/saveSystem.test.js public/engines/__tests__/rpg-topdown/logicRuntime.test.js public/engines/__tests__/unified-3d/ModeInterface.test.mjs public/engines/__tests__/unified-3d/TerrainRuntime3D.test.mjs",
    "test:coverage": "c8 node --test --test-concurrency=1 server/",
    "beta:check": "npm run test:server && npm run test:engines && npm run studio:build",
    "beta:build:mac": "npm run beta:check && electron-builder --mac",
    "beta:build:win": "npm run beta:check && electron-builder --win",
    "beta:build:linux": "npm run beta:check && electron-builder --linux",
    "ai:validate": "npm run test:ai && node scripts/validate-opencode-zen.js",
    "studio:dev": "vite",
    "studio:build": "vite build",
    "studio:preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.1",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/filesystem": "^8.1.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/preferences": "^8.0.0",
    "@huggingface/transformers": "^3.0.0-alpha.19",
    "@monaco-editor/react": "^4.7.0",
    "@orama/orama": "^3.0.0",
    "cannon-es": "^0.20.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "lucide-react": "^1.16.0",
    "monaco-editor": "^0.55.1",
    "multer": "^2.2.0",
    "onnxruntime-web": "^1.19.2",
    "parse-magica-voxel": "^2.1.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.183.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^40.1.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "build": {
    "appId": "com.redglitch.engine",
    "productName": "Redglitch Game Studio",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!builds/**/*",
      "!scratch/**/*",
      "!backend/venv/**/*",
      "!backend/models/**/*",
      "!portfolio-screenshots/**/*",
      "!website/**/*",
      "!.gemini/**/*",
      "!.antigravitycli/**/*",
      "!projects/**/*",
      "projects/Default Project/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "canmertdogan",
      "repo": "redglitch-engine",
      "releaseType": "prerelease"
    },
    "win": {
      "target": "nsis",
      "icon": "favicon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon.icns",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icons/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "favicon.ico",
      "uninstallerIcon": "favicon.ico"
    }
  }
}

{
  "id": "sample_interactive_cutscene",
  "name": "Sample Interactive Cutscene",
  "description": "A demonstration of the interactive cutscene format",
  "version": "1.0",
  "metadata": {
    "created": "2026-02-05",
    "author": "RedGlitch Studio",
    "tags": ["tutorial", "interactive", "dialogue"]
  },
  "timeline": {
    "duration": 45.0,
    "fps": 60,
    "tracks": [
      {
        "id": "track_1",
        "name": "Main Character",
        "type": "actor",
        "visible": true,
        "keyframes": [
          {
            "time": 0,
            "properties": {
              "sprite": "player",
              "x": 100,
              "y": 200,
              "scale": 1.0,
              "rotation": 0,
              "opacity": 1.0
            },
            "easing": "linear"
          },
          {
            "time": 10,
            "properties": {
              "x": 300,
              "y": 200
            },
            "easing": "ease-out"
          }
        ]
      },
      {
        "id": "track_2", 
        "name": "Background Music",
        "type": "audio",
        "visible": true,
        "keyframes": [
          {
            "time": 0,
            "properties": {
              "file": "background_music.mp3",
              "volume": 0.7,
              "loop": true,
              "fadeIn": 2.0
            }
          }
        ]
      },
      {
        "id": "track_3",
        "name": "Interactive Dialogue",
        "type": "interaction",
        "visible": true,
        "keyframes": [
          {
            "time": 12,
            "type": "dialogue",
            "data": {
              "speaker": "protagonist",
              "text": "I wonder what's behind that door...",
              "portrait": "player_portrait",
              "voiceFile": "voice_01.wav",
              "textSpeed": 50,
              "autoAdvance": false,
              "choices": [
                {
                  "text": "Open the door",
                  "action": "branch_timeline", 
                  "target": "door_open_branch",
                  "condition": null
                },
                {
                  "text": "Look around first",
                  "action": "dialogue_continue",
                  "target": "look_around_dialogue",
                  "condition": null
                },
                {
                  "text": "Leave this place",
                  "action": "set_variable",
                  "variable": "left_area",
                  "value": true,
                  "then": "branch_timeline",
                  "target": "leaving_branch"
                }
              ]
            }
          },
          {
            "time": 30,
            "type": "variable_set",
            "data": {
              "variable": "scene_progress",
              "value": "midpoint"
            }
          }
        ]
      }
    ]
  },
  "branches": {
    "door_open_branch": {
      "duration": 20.0,
      "tracks": [
        {
          "id": "door_branch_actor",
          "name": "Character opens door",
          "type": "actor",
          "keyframes": [
            {
              "time": 0,
              "properties": {
                "sprite": "player",
                "x": 300,
                "y": 200,
                "animation": "door_opening"
              }
            }
          ]
        },
        {
          "id": "door_branch_dialogue",
          "name": "Door dialogue",
          "type": "interaction", 
          "keyframes": [
            {
              "time": 3,
              "type": "dialogue",
              "data": {
                "speaker": "protagonist",
                "text": "The door creaks open, revealing a mysterious chamber...",
                "autoAdvance": true,
                "delay": 3.0
              }
            }
          ]
        }
      ]
    },
    "leaving_branch": {
      "duration": 15.0,
      "tracks": [
        {
          "id": "leave_actor",
          "name": "Character leaves",
          "type": "actor",
          "keyframes": [
            {
              "time": 0,
              "properties": {
                "sprite": "player", 
                "x": 300,
                "y": 200
              }
            },
            {
              "time": 10,
              "properties": {
                "x": -50,
                "y": 200,
                "opacity": 0.0
              },
              "easing": "ease-in"
            }
          ]
        }
      ]
    }
  },
  "dialogues": {
    "look_around_dialogue": {
      "nodes": [
        {
          "speaker": "protagonist",
          "text": "I should be careful. This place feels... strange.",
          "choices": [
            {
              "text": "Continue exploring",
              "action": "resume_timeline"
            },
            {
              "text": "Go back",
              "action": "branch_timeline",
              "target": "leaving_branch" 
            }
          ]
        }
      ]
    }
  },
  "variables": [
    {
      "name": "scene_progress",
      "type": "string",
      "default": "start",
      "description": "Tracks progress through the scene"
    },
    {
      "name": "left_area", 
      "type": "boolean",
      "default": false,
      "description": "Whether the player chose to leave"
    },
    {
      "name": "door_opened",
      "type": "boolean", 
      "default": false,
      "description": "Whether the door was opened"
    }
  ],
  "settings": {
    "pauseOnChoices": true,
    "allowSkipping": false,
    "allowRollback": true,
    "autosaveProgress": true,
    "exportCampaignEvents": true
  },
  "integrations": {
    "algorithmStudio": {
      "enabled": false,
      "aiDialogueGeneration": false,
      "adaptiveChoices": false
    },
    "campaignEditor": {
      "enabled": true,
      "exportVariables": ["scene_progress", "left_area", "door_opened"],
      "triggerQuests": [],
      "unlockNodes": []
    }
  }
}
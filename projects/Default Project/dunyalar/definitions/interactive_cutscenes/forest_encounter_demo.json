    "gameplayImpact": {
      "questUnlocks": ["The Lost Caravan", "Shadow in the Woods"],
      "shopAccess": ["Grateful Traveler's Wares"],
      "skillChecks": ["Perception for shadow detection", "Medicine for healing"],
      "moralityPoints": "+1 to +3 based on choices"
    }
  }

      {
        "id": "main_story_interactions",
        "name": "Story & Dialogue",
        "type": "interaction",
        "visible": true,
        "keyframes": [
          {
            "time": 5,
            "type": "dialogue",
            "data": {
              "speaker": "narrator",
              "text": "You step into a peaceful forest clearing, sunlight filtering through ancient trees...",
              "textSpeed": 40,
              "autoAdvance": true,
              "delay": 4.0,
              "style": {
                "color": "#e8f4f8",
                "background": "rgba(0,0,0,0.7)",
                "position": "top"
              }
            }
          },
          {
            "time": 13,
            "type": "dialogue",
            "data": {
              "speaker": "player",
              "text": "Wait... someone's there! They look hurt!",
              "portrait": "player_concerned",
              "textSpeed": 35,
              "autoAdvance": false,
              "choices": [
                {
                  "text": "→ Rush over to help immediately",
                  "action": "set_variable",
                  "variable": "player_impulsive", 
                  "value": true,
                  "then": "branch_timeline",
                  "target": "immediate_help_branch"
                },
                {
                  "text": "→ Approach cautiously and observe",
                  "action": "set_variable",
                  "variable": "player_cautious",
                  "value": true,
                  "then": "dialogue_continue",
                  "target": "cautious_approach"
                },
                {
                  "text": "→ Call out from a distance",
                  "action": "set_variable", 
                  "variable": "player_careful",
                  "value": true,
                  "then": "dialogue_continue",
                  "target": "distant_call"
                }
              ]
            }
          },
          {
            "time": 28,
            "type": "dialogue",
            "data": {
              "speaker": "wounded_traveler",
              "text": "*coughs weakly* Please... help me...",
              "portrait": "traveler_wounded_face",
              "textSpeed": 25,
              "autoAdvance": false,
              "voiceFile": "traveler_weak_plea.wav",
              "style": {
                "color": "#ffaaaa",
                "textShadow": "1px 1px 2px rgba(0,0,0,0.8)"
              }
            }
          },
          {
            "time": 33,
            "type": "dialogue",
            "data": {
              "speaker": "player",
              "text": "You're badly injured! What happened to you?",
              "portrait": "player_concerned",
              "textSpeed": 30,
              "autoAdvance": false,
              "choices": [
                {
                  "text": "→ Give them a healing potion",
                  "action": "branch_timeline",
                  "target": "healing_branch",
                  "condition": "inventory.has('healing_potion')"
                },
                {
                  "text": "→ Bandage their wounds with cloth",
                  "action": "branch_timeline",
                  "target": "bandage_branch",
                  "condition": null
                },
                {
                  "text": "→ Ask what attacked them",
                  "action": "dialogue_continue",
                  "target": "attack_inquiry"
                },
                {
                  "text": "→ Look around for threats first",
                  "action": "set_variable",
                  "variable": "noticed_shadow",
                  "value": true,
                  "then": "dialogue_continue", 
                  "target": "threat_awareness"
                }
              ]
            }
          },
          {
            "time": 42,
            "type": "dialogue",
            "data": {
              "speaker": "wounded_traveler", 
              "text": "Shadow beasts... they came from nowhere... took my supplies...",
              "portrait": "traveler_fearful",
              "textSpeed": 30,
              "autoAdvance": true,
              "delay": 3.5
            }
          },
          {
            "time": 47,
            "type": "dialogue",
            "data": {
              "speaker": "narrator",
              "text": "A chill runs down your spine. Something is watching you both from the shadows...",
              "textSpeed": 35,
              "autoAdvance": false,
              "style": {
                "color": "#aa88ff",
                "background": "rgba(20,0,40,0.8)"
              },
              "choices": [
                {
                  "text": "→ 'We need to get out of here NOW!'",
                  "action": "branch_timeline",
                  "target": "escape_branch"
                },
                {
                  "text": "→ 'Stay calm, I'll protect you.'",
                  "action": "set_variable",
                  "variable": "player_brave",
                  "value": true,
                  "then": "branch_timeline",
                  "target": "protection_branch"
                },
                {
                  "text": "→ Quietly ready your weapon",
                  "action": "set_variable",
                  "variable": "player_prepared",
                  "value": true,
                  "then": "branch_timeline",
                  "target": "combat_ready_branch"
                }
              ]
            }
          }
        ]
      }
    ]
  },
  "branches": {

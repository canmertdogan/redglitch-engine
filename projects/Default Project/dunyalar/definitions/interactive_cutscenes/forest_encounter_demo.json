            {
              "time": 8,
              "properties": {
                "sprite": "shadow_beast_emerge",
                "x": 450,
                "y": 200,
                "scale": 2.0
              }
            }
          ]
        },
        {
          "id": "combat_dialogue",
          "name": "Battle Ready",
          "type": "interaction",
          "keyframes": [
            {
              "time": 1,
              "type": "dialogue",
              "data": {
                "speaker": "player", 
                "text": "I can sense something out there. Stay behind me.",
                "portrait": "player_determined",
                "autoAdvance": true,
                "delay": 3.0
              }
            },
            {
              "time": 5,
              "type": "dialogue",
              "data": {
                "speaker": "wounded_traveler",
                "text": "You're ready for them... you're not like other travelers...",
                "portrait": "traveler_impressed",
                "autoAdvance": false,
                "choices": [
                  {
                    "text": "→ 'I've faced worse than shadow beasts.'",
                    "action": "resume_timeline"
                  },
                  {
                    "text": "→ 'Just stay quiet and let me handle this.'",
                    "action": "set_variable",
                    "variable": "player_stern",
                    "value": true,
                    "then": "resume_timeline"
                  }
                ]
              }
            },
            {
              "time": 10,
              "type": "dialogue",
              "data": {
                "speaker": "narrator",
                "text": "A shadow beast emerges from the treeline, drawn by the scent of blood...",
                "style": {
                  "color": "#ff6666",
                  "background": "rgba(40,0,0,0.9)"
                },
                "autoAdvance": false,
                "choices": [
                  {
                    "text": "→ Engage the beast in combat",
                    "action": "branch_timeline",
                    "target": "boss_fight_sequence"
                  },
                  {
                    "text": "→ Try to intimidate it away",
                    "action": "branch_timeline", 
                    "target": "intimidation_attempt"
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    "protection_branch": {
      "duration": 18.0,
      "tracks": [
        {
          "id": "protective_stance",
          "name": "Guardian Position",
          "type": "actor",
          "keyframes": [
            {
              "time": 0,
              "properties": {
                "sprite": "player_protective_stance",
                "x": 220,
                "y": 250
              }
            },
            {
              "time": 5,
              "properties": {
                "sprite": "shield_glow_effect",
                "scale": 1.8
              }
            }
          ]
        },
        {
          "id": "protection_dialogue",
          "name": "Reassuring Words",
          "type": "interaction",
          "keyframes": [
            {
              "time": 1,
              "type": "dialogue",
              "data": {
                "speaker": "wounded_traveler",
                "text": "You... you'd protect a stranger? Even with danger approaching?",
                "portrait": "traveler_moved",
                "autoAdvance": false,
                "choices": [
                  {
                    "text": "→ 'Everyone deserves protection.'",
                    "action": "set_variable",
                    "variable": "player_noble",
                    "value": true,
                    "then": "dialogue_continue",
                    "target": "noble_response"
                  },
                  {
                    "text": "→ 'I won't let them hurt you.'",
                    "action": "set_variable",
                    "variable": "player_determined",
                    "value": true,
                    "then": "resume_timeline"
                  }
                ]
              }
            },
            {
              "time": 8,
              "type": "dialogue",
              "data": {
                "speaker": "wounded_traveler",
                "text": "I haven't met someone like you in years... there's still hope in this world.",
                "portrait": "traveler_hopeful",
                "autoAdvance": true,
                "delay": 4.0
              }
            },
            {
              "time": 13,
              "type": "variable_set",
              "data": {
                "variable": "traveler_trust",
                "value": 20
              }
            },
            {
              "time": 14,
              "type": "variable_set",
              "data": {
                "variable": "reputation_protector",
                "value": true
              }
            }
          ]
        }
      ]
    }
  },
  "dialogues": {
    "cautious_approach": {
      "nodes": [
        {
          "speaker": "player",
          "text": "I should be careful... but they clearly need help.",
          "choices": [
            {
              "text": "Continue approaching slowly",
              "action": "resume_timeline"
            }
          ]
        }
      ]
    },
    "distant_call": {
      "nodes": [
        {
          "speaker": "player",
          "text": "HEY! Are you alright over there?",
          "choices": [
            {
              "text": "Wait for a response",
              "action": "resume_timeline"
            }
          ]
        }
      ]
    },
    "attack_inquiry": {
      "nodes": [
        {
          "speaker": "wounded_traveler",
          "text": "Shadow beasts... they hunt in packs... struck without warning...",
          "choices": [
            {
              "text": "How many were there?",
              "action": "dialogue_continue",
              "target": "pack_size_info"
            },
            {
              "text": "When did this happen?",
              "action": "resume_timeline"
            }
          ]
        }
      ]
    },
    "threat_awareness": {
      "nodes": [
        {
          "speaker": "player",
          "text": "*scanning the forest* We're not alone here. Something's watching us.",
          "choices": [
            {
              "text": "Stay alert and help them",
              "action": "resume_timeline"
            }
          ]
        }
      ]
    },
    "noble_response": {
      "nodes": [
        {
          "speaker": "wounded_traveler", 
          "text": "The world needs more people like you... I won't forget this kindness.",
          "choices": [
            {
              "text": "Focus on getting you to safety",
              "action": "resume_timeline"
            }
          ]
        }
      ]
    }
  },
  "variables": [
    {
      "name": "player_impulsive",
      "type": "boolean", 
      "default": false,
      "description": "Player chose to rush in and help immediately"
    },
    {
      "name": "player_cautious",
      "type": "boolean",
      "default": false,
      "description": "Player chose to approach carefully and observe"
    },
    {
      "name": "player_careful",
      "type": "boolean",
      "default": false,
      "description": "Player chose to call out from a safe distance"
    },
    {
      "name": "player_brave",
      "type": "boolean",
      "default": false,
      "description": "Player chose to be protective and brave"
    },
    {
      "name": "player_prepared",
      "type": "boolean",
      "default": false,
      "description": "Player readied weapon and prepared for combat"
    },
    {
      "name": "player_noble",
      "type": "boolean",
      "default": false,
      "description": "Player expressed noble ideals about protecting others"
    },
    {
      "name": "traveler_trust",
      "type": "integer",
      "default": 0,
      "description": "How much the traveler trusts the player (0-20)"
    },
    {
      "name": "used_healing_potion",
      "type": "boolean",
      "default": false,
      "description": "Whether player used a healing potion on the traveler"
    },
    {
      "name": "noticed_shadow",
      "type": "boolean", 
      "default": false,
      "description": "Player noticed the shadow figure watching"
    },
    {
      "name": "reputation_protector",
      "type": "boolean",
      "default": false,
      "description": "Player gained reputation as a protector of innocents"
    }
  ],
  "settings": {
    "pauseOnChoices": true,
    "allowSkipping": false,
    "allowRollback": true,
    "autosaveProgress": true,
    "exportCampaignEvents": true,
    "contextualChoices": true,
    "dynamicMusic": true
  },
  "integrations": {
    "algorithmStudio": {
      "enabled": true,
      "aiDialogueGeneration": false,
      "adaptiveChoices": true,
      "dynamicNarration": true,
      "emotionTracking": true
    },
    "campaignEditor": {
      "enabled": true,
      "exportVariables": [
        "player_impulsive", "player_cautious", "player_brave", "player_prepared",
        "traveler_trust", "used_healing_potion", "reputation_protector"
      ],
      "triggerQuests": [
        "shadow_beast_investigation", "traveler_escort_mission", "forest_protection_quest"
      ],
      "unlockNodes": [
        "traveler_shop_access", "reputation_based_dialogue", "shadow_beast_knowledge"
      ],
      "affectRelationships": {
        "forest_travelers_guild": "+reputation_protector",
        "shadow_beast_hunters": "+noticed_shadow", 
        "healing_potion_vendors": "-used_healing_potion"
      }
    }
  },
  "levelContext": {
    "location": "Whispering Woods - Ancient Clearing",
    "levelPhase": "exploration",
    "playerLevel": "3-7",
    "recommendedItems": ["healing_potion", "rope", "torch"],
    "followUpEvents": {
      "if_helped_traveler": "traveler_becomes_merchant_contact",
      "if_combat_ready": "shadow_beast_hunter_reputation",
      "if_used_potion": "alchemist_guild_recognition"

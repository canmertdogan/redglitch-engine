        {
          "id": "rush_dialogue",
          "name": "Impulsive Help",
          "type": "interaction",
          "keyframes": [
            {
              "time": 1,
              "type": "dialogue", 
              "data": {
                "speaker": "player",
                "text": "Don't worry! I'm here to help!",
                "autoAdvance": true,
                "delay": 2.5
              }
            },
            {
              "time": 4,
              "type": "dialogue",
              "data": {
                "speaker": "wounded_traveler",
                "text": "Thank you... you have a kind heart...",
                "portrait": "traveler_grateful",
                "autoAdvance": true,
                "delay": 3.0
              }
            },
            {
              "time": 8,
              "type": "variable_set",
              "data": {
                "variable": "traveler_trust",
                "value": 10
              }
            }
          ]
        }
      ]
    },
    "healing_branch": {
      "duration": 15.0,
      "tracks": [
        {
          "id": "healing_action",

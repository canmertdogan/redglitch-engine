          "keyframes": [
            {
              "time": 1,
              "type": "dialogue",
              "data": {
                "speaker": "player",
                "text": "Here, drink this healing potion. It should help.",
                "autoAdvance": true,
                "delay": 3.0
              }
            },
            {
              "time": 5,
              "type": "dialogue",
              "data": {
                "speaker": "wounded_traveler",
                "text": "Incredible... I feel much better! You saved my life!",
                "portrait": "traveler_amazed",
                "autoAdvance": true,
                "delay": 3.5
              }
            },
            {
              "time": 9,
              "type": "variable_set",
              "data": {
                "variable": "traveler_trust",
                "value": 15
              }
            },
            {
              "time": 10,
              "type": "variable_set", 
              "data": {
                "variable": "used_healing_potion",
                "value": true
              }
            }
          ]
        }
      ]
    },
    "combat_ready_branch": {
      "duration": 25.0,
      "tracks": [
        {
          "id": "combat_preparation",

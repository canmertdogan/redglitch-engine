    { "id": "w_12", "fromNode": "n_branch_pause", "fromPort": "false", "toNode": "n_branch_hud", "toPort": "in" },
    { "id": "w_13", "fromNode": "n_chk_hud", "fromPort": "res", "toNode": "n_branch_hud", "toPort": "cond" },
    { "id": "w_13a", "fromNode": "n_get_screen", "fromPort": "val", "toNode": "n_chk_hud", "toPort": "a" },

    { "id": "w_14", "fromNode": "n_branch_hud", "fromPort": "true", "toNode": "n_hud_log", "toPort": "in" },
    { "id": "w_15", "fromNode": "n_hud_log", "fromPort": "out", "toNode": "n_hud_ui", "toPort": "in" },

    { "id": "w_16", "fromNode": "n_action_evt", "fromPort": "out", "toNode": "n_act_log", "toPort": "in" },
    { "id": "w_17", "fromNode": "n_act_log", "fromPort": "out", "toNode": "n_act_branch", "toPort": "in" },
    { "id": "w_18", "fromNode": "n_act_branch", "fromPort": "true", "toNode": "n_act_start", "toPort": "in" },
    { "id": "w_19", "fromNode": "n_act_branch", "fromPort": "false", "toNode": "n_act_resume", "toPort": "in" }
  ],
  "vars": [
    { "name": "ui_request_active", "type": "bool", "value": 0 },
    { "name": "current_screen", "type": "string", "value": "main_menu" }
  ]
}
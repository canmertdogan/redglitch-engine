{
  "nodes": [
    { "id": "n_start", "type": "evt_start", "x": 50, "y": 50, "data": {} },
    { "id": "n_load_cfg", "type": "eng_log", "x": 300, "y": 50, "data": { "msg": "Load definitions/ui.json" } },
    
    { "id": "n_req_tick", "type": "evt_tick", "x": 50, "y": 250, "data": {} },
    { "id": "n_chk_req", "type": "flow_branch", "x": 300, "y": 250, "data": {} },
    { "id": "n_get_req", "type": "var_get", "x": 200, "y": 350, "data": { "name": "ui_request_active" } },

    { "id": "n_branch_screen", "type": "flow_branch", "x": 550, "y": 250, "data": {} },

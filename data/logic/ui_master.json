    { "id": "n_hud_log", "type": "eng_log", "x": 800, "y": 650, "data": { "msg": "Render: HUD (Bars/Clock)" } },
    { "id": "n_hud_ui", "type": "eng_ui", "x": 800, "y": 750, "data": { "screen": "hud" } },

    { "id": "n_action_evt", "type": "evt_interact", "x": 1100, "y": 50, "data": {} },

    { "id": "n_act_branch", "type": "flow_branch", "x": 1350, "y": 200, "data": {} },
    { "id": "n_act_start", "type": "eng_log", "x": 1600, "y": 100, "data": { "msg": "Action: Start Game" } },
    { "id": "n_act_resume", "type": "eng_log", "x": 1600, "y": 250, "data": { "msg": "Action: Resume Game" } }


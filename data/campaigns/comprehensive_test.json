{
  "name": "Comprehensive Test Campaign",
  "description": "Full test suite for all Campaign Studio features across all three engines",
  "version": "1.0.0",
  "author": "Campaign Studio",
  "startNode": "start",
  "nodes": {
    "start": {
      "id": "start",
      "type": "start",
      "x": 100,
      "y": 300,
      "next": "intro_dialogue"
    },
    "intro_dialogue": {
      "id": "intro_dialogue",
      "type": "dialogue",
      "x": 250,
      "y": 300,
      "speaker": "Campaign Guide",
      "text": "Welcome to the Comprehensive Test Campaign! This will test all Campaign Studio features across all three engines. Are you ready?",
      "choices": [
        { "text": "Yes, let's begin!", "next": "rpg_level_1" },
        { "text": "Tell me more first", "next": "explanation_dialogue" }
      ]
    },
    "explanation_dialogue": {
      "id": "explanation_dialogue",
      "type": "dialogue",
      "x": 250,
      "y": 450,
      "speaker": "Campaign Guide",
      "text": "This campaign will take you through RPG-TopDown, ISO-Pixel, and Platformer-2D engines. Your inventory, quests, and achievements will persist across all transitions. Good luck!",
      "next": "rpg_level_1"
    },
    "rpg_level_1": {
      "id": "rpg_level_1",
      "type": "level",
      "x": 400,
      "y": 300,
      "engineType": "rpg-topdown",
      "world": "test_world_1",
      "spawnPoint": { "x": 100, "y": 100 },
      "objectives": ["Collect 3 items", "Talk to NPC"],
      "next": "branch_test"
    },
    "branch_test": {
      "id": "branch_test",
      "type": "branch",
      "x": 550,
      "y": 300,
      "condition": "flag:items_collected >= 3",
      "trueNext": "iso_level_1",
      "falseNext": "retry_dialogue"
    },
    "retry_dialogue": {
      "id": "retry_dialogue",
      "type": "dialogue",
      "x": 550,
      "y": 450,
      "speaker": "Campaign Guide",
      "text": "You need to collect at least 3 items before proceeding. Try again!",
      "next": "rpg_level_1"
    },
    "iso_level_1": {
      "id": "iso_level_1",
      "type": "level",
      "x": 700,
      "y": 300,

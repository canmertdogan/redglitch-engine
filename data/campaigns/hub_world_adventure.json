{
  "name": "Hub World Adventure",
  "description": "An open-ended campaign with a central hub and optional missions",
  "version": "1.0.0",
  "author": "Campaign Studio",
  "startNode": "start",
  "nodes": {
    "start": {
      "id": "start",
      "type": "start",
      "x": 600,
      "y": 50,
      "next": "intro_hub"
    },
    "intro_hub": {
      "id": "intro_hub",
      "type": "hub",
      "x": 600,
      "y": 200,
      "engineType": "rpg-topdown",
      "world": "central_hub",
      "spawnPoint": { "x": 200, "y": 200 },
      "shopAvailable": true,
      "innAvailable": true,
      "questBoardAvailable": true,
      "healPlayer": true,
      "npcs": ["shop_keeper", "inn_keeper", "quest_master", "blacksmith"],
      "exits": [
        { "name": "Forest Mission", "next": "forest_check" },
        { "name": "Cave Mission", "next": "cave_check" },
        { "name": "Tower Mission", "next": "tower_check" },
        { "name": "Final Mission", "next": "final_check" }
      ]
    },
    "forest_check": {
      "id": "forest_check",
      "type": "branch",
      "x": 200,
      "y": 400,
      "condition": "!flag:forest_complete",
      "trueNext": "forest_mission",
      "falseNext": "mission_already_done"
    },
    "forest_mission": {
      "id": "forest_mission",
      "type": "level",
      "x": 200,
      "y": 550,
      "engineType": "rpg-topdown",
      "world": "enchanted_forest",
      "spawnPoint": { "x": 100, "y": 100 },
      "objectives": ["Find the lost child", "Defeat forest guardian"],
      "next": "forest_reward"
    },
    "forest_reward": {
      "id": "forest_reward",
      "type": "reward",
      "x": 200,
      "y": 700,
      "rewards": {
        "items": [
          { "id": "forest_amulet", "quantity": 1 },
          { "id": "gold", "quantity": 100 }
        ],
        "achievements": ["forest_protector"],
        "flags": { "forest_complete": true, "missions_complete": 1 }
      },
      "next": "return_to_hub_1"
    },
    "cave_check": {
      "id": "cave_check",
      "type": "branch",
      "x": 450,
      "y": 400,
      "condition": "!flag:cave_complete",
      "trueNext": "cave_mission",
      "falseNext": "mission_already_done"
    },
    "cave_mission": {
      "id": "cave_mission",
      "type": "level",
      "x": 450,
      "y": 550,
      "engineType": "iso-pixel",
      "world": "crystal_caves",
      "spawnPoint": { "x": 50, "y": 50, "z": 0 },
      "objectives": ["Mine rare crystals", "Defeat cave trolls"],
      "next": "cave_reward"
    },
    "cave_reward": {
      "id": "cave_reward",
      "type": "reward",
      "x": 450,
      "y": 700,
      "rewards": {
        "items": [
          { "id": "magic_crystal", "quantity": 3 },
          { "id": "gold", "quantity": 150 }
        ],
        "achievements": ["crystal_hunter"],
        "flags": { "cave_complete": true, "missions_complete": 2 }
      },
      "next": "return_to_hub_1"
    },
    "tower_check": {
      "id": "tower_check",
      "type": "branch",
      "x": 750,
      "y": 400,
      "condition": "!flag:tower_complete",
      "trueNext": "tower_mission",
      "falseNext": "mission_already_done"
    },
    "tower_mission": {
      "id": "tower_mission",
      "type": "level",
      "x": 750,
      "y": 550,
      "engineType": "platformer-2d",
      "world": "wizard_tower",
      "spawnPoint": { "x": 50, "y": 450 },
      "objectives": ["Climb to the top", "Retrieve ancient tome"],
      "next": "tower_reward"
    },
    "tower_reward": {
      "id": "tower_reward",
      "type": "reward",
      "x": 750,
      "y": 700,
      "rewards": {
        "items": [
          { "id": "ancient_tome", "quantity": 1 },
          { "id": "gold", "quantity": 200 }
        ],
        "achievements": ["scholar"],
        "flags": { "tower_complete": true, "missions_complete": 3 }
      },
      "next": "return_to_hub_1"
    },
    "mission_already_done": {
      "id": "mission_already_done",
      "type": "dialogue",
      "x": 1000,
      "y": 400,
      "speaker": "Quest Master",
      "text": "You've already completed this mission!",
      "next": "return_to_hub_1"
    },
    "return_to_hub_1": {
      "id": "return_to_hub_1",
      "type": "dialogue",
      "x": 600,
      "y": 850,
      "speaker": "System",
      "text": "Mission complete! Returning to hub...",
      "next": "intro_hub"
    },
    "final_check": {
      "id": "final_check",
      "type": "if-statement",
      "x": 1000,
      "y": 200,
      "conditions": [
        {
          "flag": "missions_complete >= 3",
          "next": "final_unlock"
        }
      ],
      "defaultNext": "not_ready_dialogue"
    },
    "not_ready_dialogue": {
      "id": "not_ready_dialogue",
      "type": "dialogue",
      "x": 1200,
      "y": 300,
      "speaker": "Quest Master",
      "text": "Complete at least 3 missions before attempting the final challenge!",
      "next": "intro_hub"
    },
    "final_unlock": {
      "id": "final_unlock",
      "type": "dialogue",
      "x": 1200,
      "y": 100,
      "speaker": "Quest Master",
      "text": "You've proven yourself worthy. The path to the final challenge is now open!",
      "next": "final_mission_choice"
    },
    "final_mission_choice": {
      "id": "final_mission_choice",
      "type": "dialogue",
      "x": 1400,
      "y": 100,
      "speaker": "Quest Master",
      "text": "This will be your greatest challenge. Are you ready?",
      "choices": [
        { "text": "Yes, I'm ready!", "next": "final_mission" },
        { "text": "Let me prepare more", "next": "intro_hub" }
      ]
    },
    "final_mission": {
      "id": "final_mission",
      "type": "boss-rush",
      "x": 1600,
      "y": 100,
      "engineType": "rpg-topdown",
      "bosses": [
        {
          "world": "guardian_arena_1",
          "spawnPoint": { "x": 300, "y": 300 },
          "bossName": "Forest Guardian",
          "engineType": "rpg-topdown"
        },
        {
          "world": "guardian_arena_2",
          "spawnPoint": { "x": 150, "y": 150, "z": 0 },
          "bossName": "Cave Titan",
          "engineType": "iso-pixel"
        },
        {
          "world": "guardian_arena_3",
          "spawnPoint": { "x": 100, "y": 400 },
          "bossName": "Tower Warden",
          "engineType": "platformer-2d"
        }
      ],
      "restoreHealthBetween": true,
      "rewards": {
        "items": [{ "id": "legendary_sword", "quantity": 1 }],
        "achievements": ["champion_of_the_realm"]
      },
      "next": "victory_cutscene"
    },
    "victory_cutscene": {
      "id": "victory_cutscene",
      "type": "cutscene",
      "x": 1800,
      "y": 100,
      "cutsceneName": "final_victory",
      "skippable": false,
      "next": "completion"
    },
    "completion": {
      "id": "completion",
      "type": "dialogue",
      "x": 2000,
      "y": 100,
      "speaker": "Narrator",
      "text": "Congratulations, Champion! You have mastered all challenges and brought peace to the realm.",
      "next": null
    }
  },
  "metadata": {
    "pattern": "hub-based",
    "difficulty": "variable",
    "optional_missions": 3,
    "required_missions": 3,
    "estimatedPlaytime": "60-90 minutes"
  }
}
